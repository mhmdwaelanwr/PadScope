<Window x:Class="PadScope.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PadScope" Height="760" Width="1180" MinHeight="640" MinWidth="980">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="PadScope" FontSize="34" FontWeight="Bold" />
                <TextBlock Text="Gamepad diagnostics and compatibility toolkit for Windows" Style="{StaticResource MutedText}" FontSize="15" Margin="0,4,0,0" />
            </StackPanel>

            <Border Grid.Column="1" Style="{StaticResource Card}" Padding="14,10">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Fill="{StaticResource BrushPrimary}" Margin="0,0,8,0" />
                    <TextBlock x:Name="StatusText" Text="Ready" Style="{StaticResource MutedText}" />
                </StackPanel>
            </Border>
        </Grid>

        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,18">
            <Border Style="{StaticResource Card}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Detected" Style="{StaticResource MutedText}" />
                    <TextBlock x:Name="DeviceCountText" Text="0" FontSize="28" FontWeight="Bold" Margin="0,6,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Profile Matches" Style="{StaticResource MutedText}" />
                    <TextBlock x:Name="ProfileCountText" Text="0" FontSize="28" FontWeight="Bold" Margin="0,6,0,0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,12,0">
                <StackPanel>
                    <TextBlock Text="Audio Probe" Style="{StaticResource MutedText}" />
                    <TextBlock Text="Locked" FontSize="24" FontWeight="Bold" Margin="0,6,0,0" Foreground="{StaticResource BrushWarning}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Last Scan" Style="{StaticResource MutedText}" />
                    <TextBlock x:Name="LastScanText" Text="Never" FontSize="20" FontWeight="Bold" Margin="0,8,0,0" />
                </StackPanel>
            </Border>
        </UniformGrid>

        <TabControl Grid.Row="2">
            <TabItem Header="Dashboard">
                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="1*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource Card}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,14">
                                <Button Content="Scan Controllers" Width="150" Margin="0,0,10,0" Click="ScanButton_Click" />
                                <Button Content="Export JSON" Width="120" Margin="0,0,10,0" Style="{StaticResource SecondaryButton}" Click="ExportJsonButton_Click" />
                                <Button Content="Export Markdown" Width="150" Margin="0,0,10,0" Style="{StaticResource SecondaryButton}" Click="ExportMarkdownButton_Click" />
                                <Button Content="Clear" Width="90" Style="{StaticResource SecondaryButton}" Click="ClearButton_Click" />
                            </StackPanel>

                            <DataGrid x:Name="ReportsGrid"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      SelectionChanged="ReportsGrid_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Device" Binding="{Binding Device.DisplayName}" Width="2*" />
                                    <DataGridTextColumn Header="Profile" Binding="{Binding ProfileName}" Width="180" />
                                    <DataGridTextColumn Header="Risk" Binding="{Binding RecommendedRiskLevel}" Width="90" />
                                    <DataGridTextColumn Header="VID" Binding="{Binding Device.VendorId}" Width="70" />
                                    <DataGridTextColumn Header="PID" Binding="{Binding Device.ProductId}" Width="70" />
                                    <DataGridTextColumn Header="Connection" Binding="{Binding Device.ConnectionType}" Width="110" />
                                    <DataGridTextColumn Header="Source" Binding="{Binding Device.Source}" Width="150" />
                                    <DataGridTextColumn Header="Audio" Binding="{Binding WindowsAudioEndpoint}" Width="110" />
                                    <DataGridTextColumn Header="DS4 Audio" Binding="{Binding Ds4AudioProtocol}" Width="110" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource Card}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,12">
                                <TextBlock Text="Selected Device" FontSize="19" FontWeight="Bold" VerticalAlignment="Center" />
                                <Button Content="Copy" Width="76" Margin="12,0,0,0" Style="{StaticResource SecondaryButton}" Click="CopyDetailsButton_Click" />
                            </StackPanel>

                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <TextBlock x:Name="DetailsText" Text="Run a scan, then select a device." TextWrapping="Wrap" Style="{StaticResource MutedText}" />
                            </ScrollViewer>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="Profiles">
                <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Compatibility Profiles" FontSize="22" FontWeight="Bold" />
                            <TextBlock Text="These profiles are starter records. They are intentionally conservative until real scan reports confirm VID/PID, HID shape, and feature behavior." Style="{StaticResource MutedText}" Margin="0,8,0,18" TextWrapping="Wrap" />

                            <DataGrid AutoGenerateColumns="False" IsReadOnly="True" ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=ProfileRows}" MinHeight="260">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Profile" Binding="{Binding Name}" Width="2*" />
                                    <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="160" />
                                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="190" />
                                    <DataGridTextColumn Header="Evidence needed" Binding="{Binding EvidenceNeeded}" Width="3*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <TabItem Header="Feature Tests">
                <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,14">
                            <TextBlock Text="Feature Test Registry" FontSize="22" FontWeight="Bold" />
                            <TextBlock Text="This table is generated from PadScope.Core.Testing.FeatureTestRegistry. Features stay locked until their stage and safety gates are ready." Style="{StaticResource MutedText}" Margin="0,8,0,14" TextWrapping="Wrap" />
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Explain Selected Test" Width="170" Style="{StaticResource SecondaryButton}" Click="ExplainSelectedFeatureButton_Click" />
                            </StackPanel>
                        </StackPanel>

                        <DataGrid x:Name="FeatureTestsGrid"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  ItemsSource="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=FeatureTestRows}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Feature" Binding="{Binding Name}" Width="2*" />
                                <DataGridTextColumn Header="Stage" Binding="{Binding Stage}" Width="140" />
                                <DataGridTextColumn Header="Risk" Binding="{Binding RiskLevel}" Width="105" />
                                <DataGridTextColumn Header="Target" Binding="{Binding RequiresSelectedDevice}" Width="90" />
                                <DataGridTextColumn Header="Confirm" Binding="{Binding RequiresUserConfirmation}" Width="90" />
                                <DataGridTextColumn Header="State" Binding="{Binding State}" Width="100" />
                                <DataGridTextColumn Header="Goal" Binding="{Binding Goal}" Width="3*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </TabItem>

            <TabItem Header="Audio Lab">
                <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock Text="Audio Lab" FontSize="22" FontWeight="Bold" />
                        <TextBlock Text="DS4-style speaker/headset audio probing is experimental. It will stay locked until the scanner can identify the target controller safely." Style="{StaticResource MutedText}" Margin="0,8,0,18" TextWrapping="Wrap" />
                        <Button Content="Open Audio Lab Warning" Width="180" Click="AudioLabButton_Click" />
                    </StackPanel>
                </Border>
            </TabItem>

            <TabItem Header="Roadmap">
                <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock Text="Next Engineering Milestones" FontSize="22" FontWeight="Bold" Margin="0,0,0,12" />
                        <TextBlock Text="1. Validate scanner output on Marvo GT-84 over USB and Bluetooth." Style="{StaticResource MutedText}" Margin="0,0,0,8" />
                        <TextBlock Text="2. Add explicit HID report descriptor inspection." Style="{StaticResource MutedText}" Margin="0,0,0,8" />
                        <TextBlock Text="3. Add safe rumble and lightbar tests for known DS4-like devices." Style="{StaticResource MutedText}" Margin="0,0,0,8" />
                        <TextBlock Text="4. Keep compatibility profiles evidence-based." Style="{StaticResource MutedText}" Margin="0,0,0,8" />
                        <TextBlock Text="5. Add opt-in DS4 Audio Lab after safety checks." Style="{StaticResource MutedText}" />
                    </StackPanel>
                </Border>
            </TabItem>
        </TabControl>

        <TextBlock Grid.Row="3"
                   Margin="0,16,0,0"
                   Style="{StaticResource MutedText}"
                   TextWrapping="Wrap"
                   Text="Phase 1 is read-only diagnostics. No raw HID writes, rumble, lightbar, speaker, or headset packets are sent automatically." />
    </Grid>
</Window>
