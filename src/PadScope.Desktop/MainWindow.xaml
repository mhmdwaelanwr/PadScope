<Window x:Class="PadScope.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PadScope" Height="720" Width="1080" MinHeight="560" MinWidth="860">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="PadScope" FontSize="30" FontWeight="Bold" />
            <TextBlock Text="Gamepad diagnostics and compatibility toolkit for Windows" FontSize="14" Opacity="0.75" />
        </StackPanel>

        <Border Grid.Row="1" Padding="12" Margin="0,0,0,16" BorderBrush="#DDD" BorderThickness="1" CornerRadius="8">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="Scan Controllers" Width="150" Height="36" Margin="0,0,10,0" Click="ScanButton_Click" />
                    <Button Content="Export JSON" Width="120" Height="36" Margin="0,0,10,0" Click="ExportJsonButton_Click" />
                    <Button Content="Audio Lab" Width="120" Height="36" Click="AudioLabButton_Click" />
                </StackPanel>
                <TextBlock x:Name="StatusText" DockPanel.Dock="Right" VerticalAlignment="Center" Opacity="0.75" Text="Ready" />
            </DockPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="1*" />
            </Grid.ColumnDefinitions>

            <DataGrid x:Name="ReportsGrid"
                      Grid.Column="0"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionChanged="ReportsGrid_SelectionChanged">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Device" Binding="{Binding Device.DisplayName}" Width="2*" />
                    <DataGridTextColumn Header="VID" Binding="{Binding Device.VendorId}" Width="80" />
                    <DataGridTextColumn Header="PID" Binding="{Binding Device.ProductId}" Width="80" />
                    <DataGridTextColumn Header="Connection" Binding="{Binding Device.ConnectionType}" Width="110" />
                    <DataGridTextColumn Header="Audio" Binding="{Binding WindowsAudioEndpoint}" Width="130" />
                    <DataGridTextColumn Header="DS4 Audio" Binding="{Binding Ds4AudioProtocol}" Width="130" />
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Column="2" Padding="14" BorderBrush="#DDD" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Selected Device" FontSize="18" FontWeight="Bold" Margin="0,0,0,10" />
                    <TextBlock x:Name="DetailsText" Text="Run a scan, then select a device." TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <TextBlock Grid.Row="3"
                   Margin="0,16,0,0"
                   Opacity="0.65"
                   TextWrapping="Wrap"
                   Text="Phase 1 is read-only diagnostics. Rumble, lightbar, and DS4 audio probing will be added later behind explicit user confirmation." />
    </Grid>
</Window>
